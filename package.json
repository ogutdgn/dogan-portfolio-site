{
  "name": "ogutdgn-workspace",
  "private": true,
  "scripts": {
    "dev:portfolio": "pnpm --filter @ogutdgn/portfolio dev",
    "dev:tools": "pnpm --filter @ogutdgn/tools dev",
    "build:portfolio": "pnpm --filter @ogutdgn/portfolio build",
    "build:tools": "pnpm --filter @ogutdgn/tools build",
    "build": "turbo build"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
